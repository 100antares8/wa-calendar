# Google OAuth2（Google Cloud Console の「ウェブアプリケーション」）
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# 承認済みリダイレクト URI と一字一句同じにする
# - ローカル: http://localhost:3333/api/auth/callback
# - Vercel（任意）: 未設定なら VERCEL_URL から https://<デプロイ名>.vercel.app/api/auth/callback を自動使用
# - 独自ドメイン: https://あなたのドメイン/api/auth/callback を必ず両方に設定
GOOGLE_REDIRECT_URI=
